skills/styles/state.js

# User input buffer (runtime only)
skills/styles/input.txt

# Card path config (runtime routing)
skills/styles/.card_path

# Temporary response file
skills/styles/response.txt

# Pending signal file
skills/styles/.pending

# Lock files
*.lock
scheduled_tasks.lock

# User card folders (not part of engine)
test/
绿毛/

# External skill packs
nai-skills/
skills/image_gen/
